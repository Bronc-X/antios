// Secrets.xcconfig
// Public template: safe to commit.
//
// Setup:
// 1) Copy Secrets.private.xcconfig.template to Secrets.private.xcconfig
// 2) Paste your real keys into Secrets.private.xcconfig
// 3) Keep Secrets.private.xcconfig out of git

// Core endpoints
APP_API_BASE_URL = https:\/\/www.antianxiety.app

// OpenAI compatible
OPENAI_API_KEY =
OPENAI_API_BASE = https:\/\/aicanapi.com\/v1
OPENAI_MODEL = gemini-3-flash-preview
OPENAI_MODEL_FALLBACK_CHAIN = gemini-3-flash-preview,gemini-2.5-flash-nothinking,gemini-2.5-flash-lite
OPENAI_REQUEST_TIMEOUT_SEC = 20
OPENAI_EMBEDDING_API_BASE = https:\/\/aicanapi.com\/v1
OPENAI_EMBEDDING_API_KEY =
OPENAI_EMBEDDING_API_URL = https:\/\/aicanapi.com\/v1\/embeddings
OPENAI_EMBEDDING_MODEL = text-embedding-3-large
OPENAI_EMBEDDING_CACHE_TTL_SEC = 21600
OPENAI_EMBEDDING_CACHE_MAX_ENTRIES = 512
OPENAI_EMBEDDING_ENABLED = true
OPENAI_EMBEDDING_TIMEOUT_SEC = 6
OPENAI_EMBEDDING_NO_CHANNEL_COOLDOWN_SEC = 900

// Runtime tuning (no hard-coded behavior in source)
MAX_USER_CONTEXT_CACHE_TTL_SEC = 300
MAX_CHAT_CONVERSATION_CREATE_TIMEOUT_SEC = 3
MAX_CHAT_MESSAGE_PERSIST_MAX_RETRIES = 3
MAX_CHAT_MESSAGE_RETRY_BASE_DELAY_MS = 350
MAX_CHAT_CLOUD_TIMEOUT_FAST_SEC = 30
MAX_CHAT_CLOUD_TIMEOUT_THINK_SEC = 45

SUPABASE_NETWORK_RETRY_ATTEMPTS = 2
SUPABASE_NETWORK_RETRY_DELAY_MS = 400
SUPABASE_NETWORK_RETRY_MAX_DELAY_MS = 2200
SUPABASE_NETWORK_RETRY_BACKOFF_MULTIPLIER = 2.0
SUPABASE_NETWORK_RETRY_JITTER_RATIO = 0.25
SUPABASE_NETWORK_HARD_TIMEOUT_PADDING_SEC = 1.2
SUPABASE_AUTH_TIMEOUT_SEC = 8
SUPABASE_REST_TIMEOUT_READ_SEC = 8
SUPABASE_REST_TIMEOUT_WRITE_SEC = 10
SUPABASE_APP_API_TIMEOUT_SEC = 9
SUPABASE_UPLOAD_TIMEOUT_SEC = 14
MAX_INQUIRY_CACHE_TTL_SEC = 90
MAX_DASHBOARD_CACHE_TTL_SEC = 90
MAX_RAG_CACHE_TTL_SEC = 180
MAX_SCIENCE_BLOCK_CACHE_TTL_SEC = 180
MAX_PROFILE_CACHE_TTL_SEC = 300
MAX_WEARABLE_CACHE_TTL_SEC = 180

APP_API_HEALTH_COOLDOWN_SEC = 120
APP_API_CIRCUIT_TTL_SEC = 90
APP_API_FAILURE_THRESHOLD = 2
APP_API_HEALTH_TIMEOUT_SEC = 3

MAX_CHAT_REMOTE_FAILURE_THRESHOLD = 2
MAX_CHAT_REMOTE_COOLDOWN_SEC = 60
MAX_CHAT_SESSION_STATS_DEBOUNCE_MS = 800
MAX_CHAT_LOCAL_TIMEOUT_FAST_SEC = 12
MAX_CHAT_LOCAL_TIMEOUT_THINK_SEC = 18
MAX_CHAT_LOCAL_TIMEOUT_DEGRADED_SEC = 8
MAX_CHAT_REMOTE_TIMEOUT_FAST_SEC = 9
MAX_CHAT_REMOTE_TIMEOUT_THINK_SEC = 14
MAX_CHAT_REMOTE_TIMEOUT_LEGACY_SEC = 9

// Memory pipeline reliability / latency
MAX_MEMORY_MAX_CHARS = 600
MAX_MEMORY_MIN_USER_CHARS_CJK = 2
MAX_MEMORY_MIN_USER_CHARS_LATIN = 6
MAX_MEMORY_CONVERSATION_FALLBACK_LIMIT = 36
MAX_MEMORY_STORE_RETRY_ATTEMPTS = 3
MAX_MEMORY_STORE_RETRY_BASE_DELAY_MS = 250
MAX_MEMORY_RETRIEVAL_EMBED_TIMEOUT_SEC = 3.6
MAX_MEMORY_STORAGE_EMBED_TIMEOUT_SEC = 1.8
MAX_MEMORY_EMBED_ASSISTANT = false
MAX_MEMORY_ALLOW_LEXICAL_FALLBACK = false
MAX_MEMORY_MATCH_THRESHOLD = 0.7
MAX_MEMORY_RELAXED_MATCH_THRESHOLD = 0.52
MAX_MEMORY_PENDING_QUEUE_LIMIT = 800
MAX_MEMORY_PENDING_FLUSH_BATCH_SIZE = 10
MAX_MEMORY_PENDING_FLUSH_MAX_BATCHES = 10
MAX_MEMORY_BODY_SIGNAL_MAX_WRITES_PER_SYNC = 4
MAX_MEMORY_BODY_SIGNAL_HRV_LOW = 36
MAX_MEMORY_BODY_SIGNAL_RHR_HIGH = 78
MAX_MEMORY_BODY_SIGNAL_SLEEP_LOW = 70
MAX_MEMORY_BODY_SIGNAL_STEPS_LOW = 4000
MAX_MEMORY_BODY_SIGNAL_STEPS_GOOD = 9000

// RAG pipeline performance guards
MAX_RAG_LITE_MEMORY_LIMIT = 4
MAX_RAG_FULL_MEMORY_LIMIT = 8
MAX_RAG_FULL_KNOWLEDGE_LIMIT = 10
MAX_RAG_MEMORY_BLOCK_TOPN = 6
MAX_RAG_KNOWLEDGE_BLOCK_TOPN = 6
MAX_RAG_EMBED_TIMEOUT_SEC = 3.6
MAX_RAG_WEARABLE_TIMEOUT_SEC = 1.6
MAX_RAG_RERANK_ENABLED = true
MAX_RAG_RERANK_TOPN = 8
MAX_RAG_RERANK_MIN_DOCS = 4
MAX_RAG_BODY_MEMORY_BOOST = 0.24
MAX_RAG_BEHAVIOR_MEMORY_BOOST = 0.06
MAX_RAG_STRATEGY_MEMORY_BOOST = 0.10

// External rerank service limits + cache
COHERE_RERANK_ENABLED = true
COHERE_RERANK_TIMEOUT_SEC = 4
COHERE_RERANK_MIN_DOCUMENTS = 4
COHERE_RERANK_CACHE_TTL_SEC = 300
COHERE_RERANK_CACHE_MAX_ENTRIES = 256

// QPI guard policy (release gate)
QPI_GATE_MODE = warn
QPI_PROFILE = anti_anxiety
QPI_USER_LANGUAGE = zh
MIN_QUALITY_SCORE = 3.0
QPI_MIN_PASS_MODELS = 1
QUALITY_SLO_SECONDS = 6.5
QPI_SLO_EPSILON_SEC = 0.15

// Telemetry aggregation (ACK / empty retrieval / p95 latency)
MAX_TELEMETRY_ENABLED = true
MAX_TELEMETRY_FLUSH_MIN_EVENTS = 25
MAX_TELEMETRY_FLUSH_INTERVAL_SEC = 45
MAX_TELEMETRY_LATENCY_SAMPLE_LIMIT = 300

// Supabase (fill in Secrets.private.xcconfig)
SUPABASE_URL =
SUPABASE_ANON_KEY =

// Optional local/private overrides for keys and env-specific URLs.
#include? "Secrets.private.xcconfig"
